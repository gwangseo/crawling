# Streamlit Community Cloud 배포 시 사용법:
# 1. share.streamlit.io → 앱 설정 → Secrets 탭 열기
# 2. 아래 내용을 복사하여 실제 값으로 채워 붙여넣기
# (이 파일 자체는 절대 git에 커밋하지 마세요)

# Supabase DB 연결 문자열 (.env의 DB_URL과 동일한 값)
DB_URL = "postgresql+psycopg://postgres.xxxxxxxxxxxx:비밀번호@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres"

# Gemini AI API 키 (AI 분석 기능 사용 시)
GEMINI_API_KEY = "AIza..."

# Google Drive 루트 폴더 ID
GOOGLE_DRIVE_ROOT_FOLDER_ID = "1aBcDeFgH..."

# Slack 알림 Webhook URL (선택사항)
SLACK_WEBHOOK_URL = "https://hooks.slack.com/services/..."
